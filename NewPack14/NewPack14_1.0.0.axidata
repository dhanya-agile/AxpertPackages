    "ddlscritps": [
      "CREATE TABLE IF NOT EXISTS \"{{schemaName}}\".\"acttsfield5\" (\r\n    \"recordid\" numeric(16,0),\r\n    \"img\" bytea,\r\n    \"blobno\" numeric(3,0),\r\n    \"ftype\" varchar(4)\r\n);\r\n$D#",
      "CREATE OR REPLACE FUNCTION \"{{schemaName}}\".insert_into_outpatient()\n RETURNS trigger\n LANGUAGE plpgsql\nAS $function$\r\nBEGIN\r\n  INSERT INTO OutPatient (PatientId, PatientName, Date_Time, Doctor, Processed, token)\r\n  VALUES (NEW.patid, NEW.patname, NEW.timeofreg, NEW.doctor, false, NEW.token);\r\n\r\n  RETURN NEW;\r\nEND;\r\n$function$\n;\r\n$D#\r\nCREATE TRIGGER after_insert_maintable AFTER INSERT ON maint1 FOR EACH ROW EXECUTE FUNCTION insert_into_outpatient();\r\n$D#\r\n"
